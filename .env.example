# ============================================================
# Coach Steve's Hitters Lab — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database (Supabase PostgreSQL - IPv4 Shared Pooler) ---
# From: Supabase → Settings → Database → Transaction pooler → Enable "Use IPv4 connection"
DATABASE_URL=postgresql://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Auth ---
# Random secret for signing JWT session cookies (min 32 chars)
# Generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=your-random-secret-here-minimum-32-chars

# Your admin email — this account always gets the admin role automatically
OWNER_EMAIL=coach@coachstevebaseball.com

# --- App URL ---
# Set to your Render deployment URL or custom domain
APP_URL=https://coach-steves-hitters-lab.onrender.com

# --- Email (Resend) ---
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- AI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIxxxxxxxxxxxx

# --- File & Video Storage (AWS S3) ---
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_BUCKET_NAME=coach-steve-hitters-lab

# --- Node Environment ---
NODE_ENV=production
